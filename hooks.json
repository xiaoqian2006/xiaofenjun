{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/plugins/codex-macos-notifier/scripts/pre_tool_use_notify.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/plugins/codex-macos-notifier/scripts/stop_notify.py\""
          }
        ]
      }
    ]
  }
}
